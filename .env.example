OLLAMA_URL=http://localhost:11434
COMFYUI_URL=http://127.0.0.1:8188

# Optional cloud providers. Leave unset for local/offline mode.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Optional local Transformers provider. This loads lazily and may be heavy.
HF_LOCAL_MODEL=

# Bloodhound Search Mode
ENABLE_BLOODHOUND_SEARCH=true
ENABLE_ONION_SEARCH=false
TOR_SOCKS_PROXY=127.0.0.1:9050
MAX_SEARCH_RESULTS=50
SEARCH_TIMEOUT_SECONDS=20
ENABLE_SEARCH_CACHE=true
SEARCH_CACHE_TTL_HOURS=24
ENABLE_LINK_FOLLOWING=true
